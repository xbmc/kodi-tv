    "test:watch": "vitest",
    "fix:lint": "eslint --fix \"**/*.+(js|jsx|ts|tsx|astro)\"",
    "check:lint": "eslint \"**/*.+(js|jsx|ts|tsx|astro)\"",
    "fix:format": "prettier --write \"**/*.+(js|jsx|ts|tsx|astro)\"",
    "check:format": "prettier --check \"**/*.+(js|jsx|ts|tsx|astro)\""
