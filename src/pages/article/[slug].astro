---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../components/BlogPost";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const data = entry.data;

const blogPost = {
  rawMarkdownBody: entry.body || "",
  excerpt: (entry.body || "").slice(0, 195),
  timeToRead: Math.ceil((entry.body?.split(/\s+/).length || 0) / 200).toString(),
  frontmatter: {
    author: data.author || "",
    date: new Date(data.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "2-digit",
    }),
    tags: data.tags || [],
    featured_image: data.featured_image || undefined,
    title: data.title,
  },
};

let breadcrumbs = data.title + " | News";
let description = blogPost.excerpt;
let image = data.featured_image?.src || undefined;
---

<BaseLayout
  title={data.title}
  breadcrumbs={breadcrumbs}
  description={description}
  image={image}
>
  <BlogPost blogPost={blogPost} />
</BaseLayout>
