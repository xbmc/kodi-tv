---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SearchNews from "../../components/SearchNews";
import { buildTagList } from "../../hooks/TagList";
import { cleanExcerpt, calcReadTime } from "../../utils/blog";

const blogEntries = await getCollection("blog");
const sorted = blogEntries.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const posts = sorted.map(entry => ({
  fields: { slug: `/article/${entry.id}` },
  frontmatter: {
    author: entry.data.author || "",
    date: new Date(entry.data.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "2-digit",
    }),
    featured_image: entry.data.featured_image || undefined,
    tags: entry.data.tags || [],
    title: entry.data.title,
  },
  rawMarkdownBody: entry.body || "",
  timeToRead: calcReadTime(entry.body),
  excerpt: cleanExcerpt(entry.body || ""),
}));

const allPostsForTags = blogEntries.map(e => ({
  frontmatter: { tags: e.data.tags || null },
}));
const tags = buildTagList(allPostsForTags).filter(a => a.insearch);
---

<BaseLayout title="News Search" breadcrumbs="Search | News">
  <SearchNews posts={posts} tags={tags} client:load />
</BaseLayout>
