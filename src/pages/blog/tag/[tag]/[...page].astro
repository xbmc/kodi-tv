---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { BlogPostCard, NavCard, EmptyCard } from "../../../../components/Blog";
import Pager from "../../../../components/Pager";
import { buildTagList } from "../../../../hooks/TagList";

const slugify = (await import("slugify")).default;

export async function getStaticPaths({ paginate }) {
  const slugify = (await import("slugify")).default;
  const blogEntries = await getCollection("blog");

  // Get all unique tags
  const allTags = [...new Set(
    blogEntries.flatMap(e => e.data.tags || [])
  )];

  // For each tag, paginate its posts
  return allTags.flatMap(tag => {
    const tagSlug = slugify(tag, {
      lower: true,
      remove: /[^\w\s$*_+~.()'"!\-@]+/g,
    });
    const filtered = blogEntries
      .filter(e => (e.data.tags || []).includes(tag))
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

    const posts = filtered.map(entry => ({
      excerpt: entry.body?.slice(0, 300) || "",
      timeToRead: Math.ceil((entry.body?.split(/\s+/).length || 0) / 200).toString(),
      fields: { slug: `/article/${entry.id}` },
      frontmatter: {
        author: entry.data.author || "",
        date: new Date(entry.data.date).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "2-digit",
        }),
        tags: entry.data.tags || [],
        featured_image: entry.data.featured_image || undefined,
        title: entry.data.title,
      },
    }));

    return paginate(posts, {
      params: { tag: tagSlug },
      props: { tag },
      pageSize: 12,
    });
  });
}

const { page, tag } = Astro.props;
const posts = page.data;
const firsttwo = posts.slice(0, 2);
const therest = posts.slice(2);

const allBlogEntries = await getCollection("blog");
const allPostsForTags = allBlogEntries.map(e => ({
  frontmatter: { tags: e.data.tags || null },
}));
const tagList = buildTagList(allPostsForTags);

const slugify2 = (await import("slugify")).default;
const tagSlug = slugify2(tag, {
  lower: true,
  remove: /[^\w\s$*_+~.()'"!\-@]+/g,
});

const pageContext = {
  previousPagePath: page.url.prev || `/blog/tag/${tagSlug}`,
  nextPagePath: page.url.next || `/blog/tag/${tagSlug}`,
  numberOfPages: page.lastPage,
  pageNumber: page.currentPage - 1,
  humanPageNumber: page.currentPage,
  tag: tag,
};
---

<BaseLayout title={"News with the Tag: " + tag} breadcrumbs={tag + " | News"}>
  <div class="mt-12 max-w-lg mx-auto gap-5 hidden lg:grid lg:grid-cols-3 lg:max-w-none">
    {firsttwo.map(post => (
      <BlogPostCard post={post} />
    ))}
    {firsttwo.length === 1 ? <EmptyCard /> : ""}
    <NavCard tagList={tagList} />
    {therest.map(post => (
      <BlogPostCard post={post} />
    ))}
  </div>
  <div class="mt-12 max-w-lg mx-auto gap-5 grid lg:hidden">
    <NavCard tagList={tagList} />
    {posts.map(post => (
      <BlogPostCard post={post} />
    ))}
  </div>
  <Pager pageContext={pageContext} />
</BaseLayout>
