---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { BlogPostCard, NavCard, EmptyCard } from "../../../../components/Blog";
import Pager from "../../../../components/Pager";
import { buildTagList } from "../../../../hooks/TagList";
import { prepareBlogPost } from "../../../../utils/blog";

const slugify = (await import("slugify")).default;

const PAGE_SIZE = 20;

export async function getStaticPaths() {
  const slugify = (await import("slugify")).default;
  const blogEntries = await getCollection("blog");

  // Get all unique tags
  const allTags = [...new Set(blogEntries.flatMap(e => e.data.tags || []))];

  return allTags.map(tag => ({
    params: {
      tag: slugify(tag, {
        lower: true,
        remove: /[^\w\s$*_+~.()'"!\-@]+/g,
      }),
    },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const blogEntries = await getCollection("blog");
const filtered = blogEntries
  .filter(e => (e.data.tags || []).includes(tag))
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );
const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
const posts = filtered.slice(0, PAGE_SIZE).map(entry => prepareBlogPost(entry));

const firsttwo = posts.slice(0, 2);
const therest = posts.slice(2);

const allPostsForTags = blogEntries.map(e => ({
  frontmatter: { tags: e.data.tags || null },
}));
const tagList = buildTagList(allPostsForTags);

const tagSlug = slugify(tag, {
  lower: true,
  remove: /[^\w\s$*_+~.()'"!\-@]+/g,
});

const pageContext = {
  previousPagePath: `/blog/tag/${tagSlug}`,
  nextPagePath: totalPages > 1 ? `/blog/tag/${tagSlug}/page/2` : `/blog/tag/${tagSlug}`,
  numberOfPages: totalPages,
  pageNumber: 0,
  humanPageNumber: 1,
  tag: tag,
};
---

<BaseLayout title={"News with the Tag: " + tag} breadcrumbs={tag + " | News"}>
  <div
    class="mt-12 max-w-lg mx-auto gap-5 hidden lg:grid lg:grid-cols-3 lg:max-w-none"
  >
    {firsttwo.map(post => <BlogPostCard post={post} />)}
    {firsttwo.length === 1 ? <EmptyCard /> : ""}
    <NavCard tagList={tagList} />
    {therest.map(post => <BlogPostCard post={post} />)}
  </div>
  <div class="mt-12 max-w-lg mx-auto gap-5 grid lg:hidden">
    <NavCard tagList={tagList} />
    {posts.map(post => <BlogPostCard post={post} />)}
  </div>
  <Pager pageContext={pageContext} />
</BaseLayout>
