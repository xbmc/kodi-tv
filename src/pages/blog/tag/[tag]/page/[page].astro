---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import { BlogPostCard, NavCard, EmptyCard } from "../../../../../components/Blog";
import Pager from "../../../../../components/Pager";
import { buildTagList } from "../../../../../hooks/TagList";
import { prepareBlogPost } from "../../../../../utils/blog";

const slugify = (await import("slugify")).default;

const PAGE_SIZE = 20;

export async function getStaticPaths() {
  const PAGE_SIZE = 20;
  const slugify = (await import("slugify")).default;
  const blogEntries = await getCollection("blog");

  // Get all unique tags
  const allTags = [...new Set(blogEntries.flatMap(e => e.data.tags || []))];

  // For each tag, generate paths for pages 2+
  return allTags.flatMap(tag => {
    const tagSlug = slugify(tag, {
      lower: true,
      remove: /[^\w\s$*_+~.()'"!\-@]+/g,
    });
    const filtered = blogEntries.filter(e => (e.data.tags || []).includes(tag));
    const totalPages = Math.ceil(filtered.length / PAGE_SIZE);

    const paths = [];
    for (let i = 2; i <= totalPages; i++) {
      paths.push({
        params: { tag: tagSlug, page: i.toString() },
        props: { tag },
      });
    }
    return paths;
  });
}

const { tag } = Astro.props;
const pageNum = Number(Astro.params.page);

const blogEntries = await getCollection("blog");
const filtered = blogEntries
  .filter(e => (e.data.tags || []).includes(tag))
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );
const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
const start = (pageNum - 1) * PAGE_SIZE;
const posts = filtered.slice(start, start + PAGE_SIZE).map(entry => prepareBlogPost(entry));

const firsttwo = posts.slice(0, 2);
const therest = posts.slice(2);

const allPostsForTags = blogEntries.map(e => ({
  frontmatter: { tags: e.data.tags || null },
}));
const tagList = buildTagList(allPostsForTags);

const tagSlug = slugify(tag, {
  lower: true,
  remove: /[^\w\s$*_+~.()'"!\-@]+/g,
});

const pageContext = {
  previousPagePath: pageNum === 2 ? `/blog/tag/${tagSlug}` : `/blog/tag/${tagSlug}/page/${pageNum - 1}`,
  nextPagePath: pageNum < totalPages ? `/blog/tag/${tagSlug}/page/${pageNum + 1}` : `/blog/tag/${tagSlug}/page/${totalPages}`,
  numberOfPages: totalPages,
  pageNumber: pageNum - 1,
  humanPageNumber: pageNum,
  tag: tag,
};
---

<BaseLayout title={"News with the Tag: " + tag} breadcrumbs={tag + " | News"}>
  <div
    class="mt-12 max-w-lg mx-auto gap-5 hidden lg:grid lg:grid-cols-3 lg:max-w-none"
  >
    {firsttwo.map(post => <BlogPostCard post={post} />)}
    {firsttwo.length === 1 ? <EmptyCard /> : ""}
    <NavCard tagList={tagList} />
    {therest.map(post => <BlogPostCard post={post} />)}
  </div>
  <div class="mt-12 max-w-lg mx-auto gap-5 grid lg:hidden">
    <NavCard tagList={tagList} />
    {posts.map(post => <BlogPostCard post={post} />)}
  </div>
  <Pager pageContext={pageContext} />
</BaseLayout>
