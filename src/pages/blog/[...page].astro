---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { BlogPostCard, NavCard, EmptyCard } from "../../components/Blog";
import Pager from "../../components/Pager";
import { buildTagList } from "../../hooks/TagList";

export async function getStaticPaths({ paginate }) {
  const blogEntries = await getCollection("blog");
  const sorted = blogEntries.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );
  const posts = sorted.map(entry => ({
    excerpt: entry.body?.slice(0, 300) || "",
    timeToRead: Math.ceil((entry.body?.split(/\s+/).length || 0) / 200).toString(),
    fields: { slug: `/article/${entry.id}` },
    frontmatter: {
      author: entry.data.author || "",
      date: new Date(entry.data.date).toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "2-digit",
      }),
      tags: entry.data.tags || [],
      featured_image: entry.data.featured_image || undefined,
      title: entry.data.title,
    },
  }));

  return paginate(posts, { pageSize: 12 });
}

const { page } = Astro.props;
const posts = page.data;
const firsttwo = posts.slice(0, 2);
const therest = posts.slice(2);

// Build tag list from all blog posts for the NavCard
const allBlogEntries = await getCollection("blog");
const allPostsForTags = allBlogEntries.map(e => ({
  frontmatter: { tags: e.data.tags || null },
}));
const tagList = buildTagList(allPostsForTags);

// Build pagination context compatible with existing Pager component
const pageContext = {
  previousPagePath: page.url.prev || "/blog",
  nextPagePath: page.url.next || "/blog",
  numberOfPages: page.lastPage,
  pageNumber: page.currentPage - 1,
  humanPageNumber: page.currentPage,
};
---

<BaseLayout
  title="News"
  breadcrumbs="News"
  description="Get information about new releases, test builds, and other news from Team Kodi."
>
  <div
    class="mt-12 max-w-lg mx-auto gap-5 hidden lg:grid lg:grid-cols-3 lg:max-w-none"
  >
    {firsttwo.map(post => <BlogPostCard key={post.fields.slug} post={post} />)}
    {firsttwo.length === 1 ? <EmptyCard /> : ""}
    <NavCard tagList={tagList} />
    {therest.map(post => <BlogPostCard key={post.fields.slug} post={post} />)}
  </div>
  <div class="mt-12 max-w-lg mx-auto gap-5 grid lg:hidden">
    <NavCard tagList={tagList} />
    {posts.map(post => <BlogPostCard key={post.fields.slug} post={post} />)}
  </div>
  <Pager pageContext={pageContext} />
</BaseLayout>
