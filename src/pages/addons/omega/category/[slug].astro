---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import AddonCategoryLayout from "../../../../components/AddonCategoryLayout";

export async function getStaticPaths() {
  const categories = await getCollection("omegaCategories");
  return categories.map(entry => ({
    params: { slug: (entry.data as any).slug },
    props: { category: entry.data },
  }));
}

const { category } = Astro.props;
const categoryData = category as any;
---

<BaseLayout title="Omega Add-on Category List" breadcrumbs={categoryData.name + " | Category | Omega | Addons"}>
  <AddonCategoryLayout repo="Omega" data={{ category: categoryData }} />
</BaseLayout>
