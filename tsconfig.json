{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "@/*": ["./src/*"]
    },
    "noUnusedLocals": false,
    "allowJs": true
  },
  "exclude": ["node_modules", "dist", ".astro"]
}
